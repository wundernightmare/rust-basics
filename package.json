{
  "name": "rust-basics",
  "version": "0.0.0",
  "private": true,
  "description": "Node layer for rust-basics: Playwright e2e + lefthook git hooks",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "e2e": "pnpm --filter @rust-basics/e2e test",
    "e2e:ui": "pnpm --filter @rust-basics/e2e test:ui",
    "e2e:smoke": "pnpm --filter @rust-basics/e2e test:smoke",
    "e2e:report": "pnpm --filter @rust-basics/e2e report"
  },
  "devDependencies": {
    "lefthook": "^1.10.0"
  }
}
